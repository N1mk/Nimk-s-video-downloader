{
  "manifest_version": 3,
  "name": "Video downloader",
  "version": "1.0",
  "description": "One click video downloader from Youtube / Youtube Music",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "nativeMessaging"
  ],
  "host_permissions": [
    "http://localhost:8080/"
  ],
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}